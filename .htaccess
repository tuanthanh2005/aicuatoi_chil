Options -Indexes

RewriteEngine On
RewriteBase /

# Protect internal folders
RewriteRule ^(core|config|data|models|views)/ - [F,L]

# Route all requests to index.php if not a file/directory
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
